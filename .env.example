# =============================================================================
# Azure OpenAI 設定（01〜06, 09, 10 で使用）
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# 認証方式: True = API キー認証（開発向け）/ False = DefaultAzureCredential（本番向け）
USE_KEY_AUTH=True

# =============================================================================
# Azure AI Foundry / Agent Service（07, 08 で使用）
# =============================================================================
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# =============================================================================
# MCP サーバー（02, 04, 09 で使用）
# ローカルで mock_server.py を起動した場合のデフォルト値
# =============================================================================
MCP_SERVER_URI=http://localhost:8000/mcp

# =============================================================================
# Azure AI Search（06 で使用）
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your_search_api_key_here
